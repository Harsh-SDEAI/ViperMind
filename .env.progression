# QUIZ_PASS_THRESHOLD=50.0
# SECTION_TEST_PASS_THRESHOLD=55.0
# LEVEL_FINAL_PASS_THRESHOLD=60.0
# SECTION_AVERAGE_REQUIREMENT=55.0
