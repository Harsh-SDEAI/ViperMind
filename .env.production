# Production Environment Configuration
# Copy this file to .env and update with your production values

# Environment
ENVIRONMENT=production

# Database Configuration
POSTGRES_USER=vipermind_user
POSTGRES_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD
POSTGRES_DB=vipermind_prod
POSTGRES_SERVER=db

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_KEY_PREFIX=vipermind_prod

# Security - CHANGE THESE IN PRODUCTION
SECRET_KEY=CHANGE_THIS_TO_VERY_SECURE_SECRET_KEY_AT_LEAST_32_CHARACTERS
ACCESS_TOKEN_EXPIRE_MINUTES=480

# OpenAI Configuration
OPENAI_API_KEY=CHANGE_THIS_TO_YOUR_OPENAI_API_KEY

# Frontend Configuration
REACT_APP_API_URL=https://your-domain.com
REACT_APP_ENVIRONMENT=production

# Monitoring
GRAFANA_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=20