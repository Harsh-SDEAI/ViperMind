# ViperMind Environment Configuration

# Environment
ENVIRONMENT=development

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=vipermind
POSTGRES_SERVER=localhost

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_KEY_PREFIX=vipermind

# Security
SECRET_KEY=your_very_secure_secret_key_here_at_least_32_characters_long
ACCESS_TOKEN_EXPIRE_MINUTES=480

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000
REACT_APP_ENVIRONMENT=development

# Monitoring (Production)
GRAFANA_PASSWORD=admin_password_here

# SSL Configuration (Production)
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# Backup Configuration (Production)
BACKUP_S3_BUCKET=vipermind-backups
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# Email Configuration (Production)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=noreply@vipermind.com

# Sentry Configuration (Production)
SENTRY_DSN=your_sentry_dsn_here

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10